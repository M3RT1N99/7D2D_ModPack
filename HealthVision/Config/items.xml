<?xml version="1.0" encoding="UTF-8"?>
<!--
  Adds "HealthVisionGoggles": a wearable Scavenger cap + goggles that, while worn, shows a
  health bar + number above every nearby living entity (handled by the mod's C# overlay).

  Get it via the creative/dev menu, or console:  giveself HealthVisionGoggles

  NOTE: 7DTD has no Eyes/Face equip slot, so this EXTENDS a vanilla helmet (Scavenger, which
  has a cap + goggles look) and therefore occupies the Head/armor slot, so you cannot wear a
  combat helmet at the same time. The overlay detects the item by NAME, so the slot does not
  matter for the effect. (It also inherits the helmet's armor rating as a bonus.)
-->
<config>
    <append xpath="/items">
        <item name="HealthVisionGoggles">
            <property name="Extends" value="armorScavengerHelmet"/>
            <property name="CreativeMode" value="Player"/>
            <property name="EconomicValue" value="100"/>
            <property name="SellableToTrader" value="false"/>
        </item>
    </append>
</config>
